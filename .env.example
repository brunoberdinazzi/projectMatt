# App runtime
HOST=127.0.0.1
PORT=8000

# Local PostgreSQL on loopback
POSTGRES_USER=draux
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=draux
POSTGRES_PORT=5432
DATABASE_URL=postgresql://draux:CHANGE_ME@127.0.0.1:5432/draux
# Leave blank to reuse DATABASE_URL for the financial warehouse.
FINANCE_DATABASE_URL=

# For remote PostgreSQL, prefer sslmode=require in the URL or force here.
# DRAUX_DB_SSLMODE=require

# Security
AUTH_COOKIE_NAME=draux_session
AUTH_COOKIE_SECURE=true
AUTH_SESSION_TTL_HOURS=168
DRAUX_TRUSTED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:8000,http://localhost:8000
DRAUX_STRICT_SECURITY_PREFLIGHT=0

# Stable encryption key for persisted sensitive data.
# Generate with:
# python - <<'PY'
# import base64, os
# print(base64.urlsafe_b64encode(os.urandom(32)).decode())
# PY
DRAUX_DATA_KEY=

# Upload limits
DRAUX_MAX_UPLOAD_BYTES=26214400
DRAUX_MAX_TEMPLATE_BYTES=10485760

# AI providers
OLLAMA_MODEL=deepseek-r1:8b
OLLAMA_TIMEOUT_SECONDS=600
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Backup helpers
POSTGRES_BACKUP_DIR=.backups
BACKUP_PASSPHRASE=
BACKUP_REQUIRE_ENCRYPTION=0
